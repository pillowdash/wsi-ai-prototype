# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
.vscode/

# =========================
# Logs
# =========================
*.log

# =========================
# Environment variables
# =========================
.env

# =========================
# Data (keep structure only)
# =========================
data/raw/*
data/interim/*
data/processed/*

# Allow folder placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Allow demo heatmaps (optional but recommended)
!data/processed/heatmaps/
!data/processed/heatmaps/*.png

# =========================
# Model files
# =========================
models/checkpoints/
models/exported/
*.pth
*.pt

# =========================
# Large WSI / image files
# =========================
*.tif
*.tiff
*.svs
*.ndpi

# =========================
# Temp / cache
# =========================
*.tmp
*.cache/

# =========================
# Python packaging
# =========================
build/
dist/
*.egg-info/
